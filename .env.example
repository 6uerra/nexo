# ==========================
# Nexo — Variables de entorno
# Copia este archivo a .env y completa los valores.
# ==========================

# --- Aplicación ---
NODE_ENV=development
APP_NAME=Nexo

# --- URLs ---
WEB_URL=http://localhost:3000
API_URL=http://localhost:3001

# --- Base de datos (Postgres) ---
DATABASE_URL=postgresql://nexo:nexo@localhost:5432/nexo

# --- Redis (cache + jobs) ---
REDIS_URL=redis://localhost:6379

# --- Almacenamiento (MinIO local, compatible S3) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=nexo
S3_FORCE_PATH_STYLE=true

# --- Autenticación ---
JWT_SECRET=cambia-esto-en-produccion-usa-un-secreto-largo-y-aleatorio
JWT_EXPIRES_IN=7d
SESSION_COOKIE_NAME=nexo_session

# --- Email (Gmail SMTP en prod, MailHog en dev) ---
# Dev: MailHog corre en localhost:1025 sin auth
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Nexo <noreply@nexo.local>"

# Para producción con Gmail:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=tu-correo@gmail.com
# SMTP_PASS=tu-app-password-de-16-caracteres
# SMTP_FROM="Nexo <tu-correo@gmail.com>"

# --- Pagos (registro manual, sin gateway) ---
# Datos del super-admin para mostrar QR / cuenta de pago
PAYMENT_QR_URL=
PAYMENT_BANK_NAME=
PAYMENT_BANK_ACCOUNT=
PAYMENT_BANK_HOLDER=
PAYMENT_BANK_DOCUMENT=

# --- Super admin inicial (solo seed) ---
SEED_SUPERADMIN_EMAIL=admin@nexo.local
SEED_SUPERADMIN_PASSWORD=NexoAdmin2026!
SEED_SUPERADMIN_NAME=Super Admin

# --- Cron de notificaciones ---
NOTIFICATIONS_CRON=0 8 * * *
